<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Thí nghiệm ảo - Vật lý 8</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 10px;
      background: #f9f9f9;
    }
    .container {
      max-width: 1200px;
      margin: 0 auto;
    }
    .phet-frame {
      width: 100%;
      height: 650px;
      border: none;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    }
    /* Nút bật chatbot */
    .chatbot-toggle-btn {
      position: fixed;
      bottom: 20px;
      right: 20px;
      padding: 10px 16px;
      background: #4CAF50;
      color: white;
      border: none;
      border-radius: 30px;
      cursor: pointer;
      font-weight: bold;
      box-shadow: 0 3px 6px rgba(0,0,0,0.2);
      z-index: 1000;
    }
    /* Cửa sổ chatbot */
    #chatbot {
      position: fixed;
      bottom: 70px;
      right: 20px;
      width: 360px;
      height: 420px;
      background: white;
      border-radius: 12px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.25);
      display: none;
      flex-direction: column;
      z-index: 1000;
    }
    #chat-header {
      padding: 12px;
      background: #4CAF50;
      color: white;
      font-weight: bold;
      border-radius: 12px 12px 0 0;
      cursor: pointer;
    }
    #chat-body {
      flex: 1;
      padding: 12px;
      overflow-y: auto;
      font-size: 14px;
      line-height: 1.5;
      background: #fafafa;
    }
    #chat-input {
      display: flex;
      padding: 10px;
      background: white;
      border-top: 1px solid #eee;
    }
    #chat-input input {
      flex: 1;
      padding: 8px;
      border: 1px solid #ccc;
      border-radius: 4px;
    }
    #chat-input button {
      margin-left: 8px;
      padding: 8px 14px;
      background: #4CAF50;
      color: white;
      border: none;
      border-radius: 4px;
      cursor: pointer;
    }
  </style>
</head>
<body>

  <div class="container">
    <h2>Thí nghiệm: Đo hiệu điện thế và cường độ dòng điện</h2>
    <iframe 
      class="phet-frame"
      src="https://phet.colorado.edu/sims/html/circuit-construction-kit-dc-virtual-lab/latest/circuit-construction-kit-dc-virtual-lab_vi.html"
      allowfullscreen>
    </iframe>
  </div>

  <!-- Nút bật chatbot -->
  <button class="chatbot-toggle-btn" onclick="toggleChat()">💬 Hỏi trợ giảng AI</button>

  <!-- Cửa sổ chatbot -->
  <div id="chatbot">
    <div id="chat-header" onclick="toggleChat()">Trợ giảng ảo – Vật lý 8</div>
    <div id="chat-body">
      <p><strong>AI:</strong> Chào em! Em có thể hỏi về:<br>
        • Cách mắc ampe kế, vôn kế<br>
        • Đặc điểm mạch nối tiếp/song song<br>
        • Giải thích hiện tượng đèn sáng/tắt<br>
        • Ý nghĩa của hiệu điện thế, dòng điện…<br>
        Hãy đặt câu hỏi nhé!</p>
    </div>
    <div id="chat-input">
      <input type="text" id="user-input" placeholder="Nhập câu hỏi..." onkeypress="if(event.key==='Enter') sendQuestion()" />
      <button onclick="sendQuestion()">Gửi</button>
    </div>
  </div>

  <script>
    // Bật/tắt chatbot
    function toggleChat() {
      const chat = document.getElementById("chatbot");
      if (chat.style.display === "flex") {
        chat.style.display = "none";
      } else {
        chat.style.display = "flex";
      }
    }

    // Xử lý khi gửi câu hỏi
    function sendQuestion() {
      const input = document.getElementById("user-input");
      const question = input.value.trim();
      if (!question) return;

      const chatBody = document.getElementById("chat-body");
      chatBody.innerHTML += `<p><strong>Em:</strong> ${question}</p>`;
      
      // Chuyển câu hỏi về chữ thường để so sánh dễ hơn
const q = question.toLowerCase();

let reply = "Câu hỏi rất hay! Em hãy thử mô tả rõ hơn hiện tượng em đang quan sát trong thí nghiệm nhé.";

if (q.includes("mục đích")) {
  reply = "Mục đích thí nghiệm này là giúp em hiểu cách đo hiệu điện thế (U) và cường độ dòng điện (I), từ đó rút ra mối quan hệ giữa U, I và điện trở R trong đoạn mạch — nền tảng của định luật Ôm (Vật lý 9).";
} 
else if (q.includes("lý thuyết") || q.includes("cơ sở")) {
  reply = "Cơ sở lý thuyết gồm: định luật Ôm (I = U/R), đặc điểm mạch nối tiếp (I = I₁ = I₂; U = U₁ + U₂) và mạch song song (U = U₁ = U₂; I = I₁ + I₂) — theo chương trình Vật lý 8–9.";
} 
else if (q.includes("ampe kế") || q.includes("cường độ dòng điện")) {
  reply = "Ampe kế đo cường độ dòng điện. Em phải mắc nó **nối tiếp** vào mạch. Lưu ý: chọn thang đo phù hợp và mắc đúng chiều (+) → (–) để kim không quay ngược!";
}
else if (q.includes("cường độ dòng điện") && q.includes("là gì")) {
  reply = "Cường độ dòng điện (ký hiệu I, đơn vị ampe - A) cho biết mức độ mạnh yếu của dòng điện. Dòng điện càng mạnh thì cường độ càng lớn. Ampe kế dùng để đo đại lượng này.";
}
else if ((q.includes("song song") || q.includes("nối tiếp")) && q.includes("cường độ") && (q.includes("bóng") || q.includes("đèn"))) {
  reply = "Có khác nhau!<br>• Mạch <strong>nối tiếp</strong>: cường độ dòng điện qua hai bóng <strong>bằng nhau</strong>.<br>• Mạch <strong>song song</strong>: cường độ dòng điện qua mỗi bóng <strong>có thể khác nhau</strong> (tùy điện trở), nhưng tổng bằng dòng điện mạch chính.";
}
else if (q.includes("mắc mạch") || q.includes("lắp mạch") || q.includes("nối mạch") || q.includes("cách mắc")) {
  reply = "Để mắc mạch điện cơ bản, em làm theo các bước:<br>" +
          "1. <strong>Xác định thiết bị</strong>: pin (nguồn), bóng đèn, dây dẫn.<br>" +
          "2. <strong>Tạo mạch kín</strong>: nối dây từ cực (+) pin → bóng đèn → cực (–) pin.<br>" +
          "3. <strong>Thêm dụng cụ đo</strong>:<br>" +
          "&nbsp;&nbsp;• Ampe kế: mắc <strong>nối tiếp</strong> với bóng đèn.<br>" +
          "&nbsp;&nbsp;• Vôn kế: mắc <strong>song song</strong> với bóng đèn.<br>" +
          "⚠️ Lưu ý: luôn kiểm tra mạch <strong>chưa kín</strong> khi lắp, xong mới đóng mạch để tránh chập!";
} 
else if (q.includes("vôn kế") || q.includes("hiệu điện thế")) {
  reply = "Vôn kế đo hiệu điện thế. Em mắc nó **song song** với thiết bị cần đo (ví dụ: hai đầu bóng đèn). Nhớ kiểm tra thang đo trước khi ghi kết quả!";
} 
else if (q.includes("nối tiếp")) {
  reply = "Trong mạch nối tiếp: <br>• Cường độ dòng điện: I = I₁ = I₂<br>• Hiệu điện thế: U = U₁ + U₂<br>→ Tổng hiệu điện thế bằng hiệu điện thế hai đầu nguồn.";
} 
else if (q.includes("song song")) {
  reply = "Trong mạch song song:<br>• Hiệu điện thế: U = U₁ = U₂<br>• Cường độ dòng điện: I = I₁ + I₂<br>→ Dòng điện chia thành các nhánh.";
} 
else if (q.includes("đèn không sáng") || q.includes("bóng đèn") || q.includes("không sáng")) {
  reply = "Em kiểm tra: <br>1. Mạch có kín không?<br>2. Pin còn đủ hiệu điện thế không?<br>3. Dây nối có đứt hoặc lỏng không?<br>4. Ampe kế/vôn kế có mắc sai vị trí không?";
} 
else if (q.includes("sai số")) {
  reply = "Sai số có thể do: tiếp xúc kém ở dây nối, chọn thang đo quá lớn/nhỏ, hoặc kim đồng hồ chưa về vạch số 0. Em nên lặp lại 2–3 lần và lấy giá trị trung bình.";
} 
else if (q.includes("điện trở") || q.includes("r =")) {
  reply = "Điện trở R đặc trưng cho mức cản trở dòng điện của vật dẫn. Với dây dẫn thuần trở, ta có định luật Ôm: I = U/R. Trong thí nghiệm này, em có thể tính R bằng cách đo U và I rồi dùng công thức R = U/I.";
}

// Hiển thị phản hồi
chatBody.innerHTML += `<p><strong>AI:</strong> ${reply}</p>`;
chatBody.scrollTop = chatBody.scrollHeight;

      input.value = "";
    }
  </script>

</body>
</html>
